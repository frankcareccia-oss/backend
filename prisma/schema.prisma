generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    Int    @id @default(autoincrement())
  email String @unique

  /// For web login. Store a bcrypt/argon2 hash (never plaintext).
  passwordHash String

  /// Global role used to route after login (Option 1).
  systemRole SystemRole @default(user)

  /// ===============================
  /// Identity (person-level)
  /// ===============================
  firstName    String?
  lastName     String?
  phoneRaw     String?
  phoneE164    String? @db.VarChar(20)
  phoneCountry String  @default("US")

  /// PV Organization department (required for staff roles in V1)
  department PvDepartment?

  tokenVersion      Int                  @default(0)
  passwordUpdatedAt DateTime?
  resetTokens       PasswordResetToken[]

  /// ===============================
  /// Trusted Device Security (Security-V1)
  /// ===============================
  trustedDevices     TrustedDevice[]
  deviceVerifyTokens DeviceVerifyToken[]

  createdAt DateTime     @default(now())
  status    EntityStatus @default(active)
  updatedAt DateTime     @updatedAt

  merchantUsers MerchantUser[]

  // Mail events (Mail-Flow-1)
  mailEvents     MailEvent[]     @relation("MailEventActor")
  posCredential  PosCredential?
  posSetupTokens PosSetupToken[]

  @@index([phoneE164])
}

model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  tokenHash String    @unique @db.VarChar(255)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

/**
 * ===============================
 * Trusted Device Security (Security-V1)
 * ===============================
 */

model TrustedDevice {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Hash of client device identifier (never store raw value)
  deviceIdHash String @db.VarChar(255)

  /// Optional friendly label (e.g. "Frank Desktop")
  label String? @db.VarChar(120)

  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())

  /// Devices expire automatically (e.g. 90 days)
  expiresAt DateTime

  /// If revoked manually
  revokedAt DateTime?

  @@unique([userId, deviceIdHash])
  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model DeviceVerifyToken {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  deviceIdHash String @db.VarChar(255)

  tokenHash String @unique @db.VarChar(255)

  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model PosCredential {
  id Int @id @default(autoincrement())

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  pinHash String @db.VarChar(255)

  failedAttempts Int       @default(0)
  lockedUntil    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PosSetupToken {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String @unique @db.VarChar(255)

  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Merchant {
  id                Int                @id @default(autoincrement())
  name              String
  status            EntityStatus       @default(active)
  suspendedAt       DateTime?
  archivedAt        DateTime?
  statusReason      String?
  statusUpdatedAt   DateTime           @default(now())
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  merchantConsumers MerchantConsumer[]
  merchantUsers     MerchantUser[]
  stores            Store[]
  qrs               StoreQr[]
  visits            Visit[]

  // Billing (v2.02.1)
  billingAccount BillingAccount?
  invoices       Invoice[] // <-- required opposite of Invoice.merchant

  @@index([status])
}

model Store {
  id       Int     @id @default(autoincrement())
  name     String
  address1 String?
  city     String?
  state    String?
  postal   String?

  /// ===============================
  /// Store phone (location-level)
  /// ===============================
  phoneRaw     String?
  phoneE164    String? @db.VarChar(20)
  phoneCountry String  @default("US")

  /// ===============================
  /// Store contact (person to reach)
  /// ===============================
  contactName         String?         @db.VarChar(120)
  contactEmail        String?         @db.VarChar(320)
  contactPhoneRaw     String?
  contactPhoneE164    String?         @db.VarChar(20)
  contactPhoneCountry String          @default("US")

  /// ===============================
  /// Store primary contact (assigned employee)
  /// ===============================
  primaryContactStoreUserId Int?
  primaryContactStoreUser   StoreUser? @relation("StorePrimaryContact", fields: [primaryContactStoreUserId], references: [id])

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  archivedAt          DateTime?
  merchantId          Int
  status              EntityStatus    @default(active)
  statusReason        String?
  statusUpdatedAt     DateTime        @default(now())
  suspendedAt         DateTime?
  merchant            Merchant        @relation(fields: [merchantId], references: [id])
  storeConsumers      StoreConsumer[]
  qrs                 StoreQr[]
  storeUsers          StoreUser[]
  visits              Visit[]

  @@index([merchantId])
  @@index([phoneE164])
  @@index([contactPhoneE164])
  @@index([primaryContactStoreUserId])
  @@index([status])
}

model MerchantUser {
  id              Int          @id @default(autoincrement())
  merchantId      Int
  userId          Int
  role            MerchantRole
  contactEmail    String?      @db.VarChar(320)
  contactPhone    String?      @db.VarChar(32)
  status          EntityStatus @default(active)
  suspendedAt     DateTime?
  archivedAt      DateTime?
  statusReason    String?
  statusUpdatedAt DateTime     @default(now())
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  merchant        Merchant     @relation(fields: [merchantId], references: [id])
  user            User         @relation(fields: [userId], references: [id])
  storeUsers      StoreUser[]

  @@unique([merchantId, userId])
  @@index([merchantId])
  @@index([userId])
}

model StoreUser {
  id              Int                  @id @default(autoincrement())
  storeId         Int
  merchantUserId  Int
  permissionLevel StorePermissionLevel @default(admin)
  status          EntityStatus         @default(active)
  suspendedAt     DateTime?
  archivedAt      DateTime?
  statusReason    String?
  statusUpdatedAt DateTime             @default(now())
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  merchantUser    MerchantUser         @relation(fields: [merchantUserId], references: [id])
  store           Store                @relation(fields: [storeId], references: [id])

  /// Stores where this StoreUser is set as the primary contact
  primaryContactForStores Store[] @relation("StorePrimaryContact")


  @@unique([storeId, merchantUserId])
  @@index([storeId])
  @@index([merchantUserId])
}

model Consumer {
  id                Int                @id @default(autoincrement())
  /// Consumers can share an email address (NOT unique).
  email             String?
  firstName         String?
  lastName          String?
  phoneRaw          String?
  phoneE164         String?            @unique @db.VarChar(20)
  phoneCountry      String             @default("US")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  archivedAt        DateTime?
  status            EntityStatus       @default(active)
  suspendedAt       DateTime?
  phones            ConsumerPhone[]
  merchantConsumers MerchantConsumer[]
  storeConsumers    StoreConsumer[]
  visits            Visit[]

  @@index([email])
  @@index([phoneE164])
  @@index([status])
}

model ConsumerPhone {
  id         Int          @id @default(autoincrement())
  consumerId Int
  phoneE164  String       @unique @db.VarChar(20)
  isPrimary  Boolean      @default(false)
  verifiedAt DateTime?
  status     EntityStatus @default(active)
  archivedAt DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  consumer   Consumer     @relation(fields: [consumerId], references: [id])

  @@index([consumerId])
  @@index([isPrimary])
}

model MerchantConsumer {
  id              Int          @id @default(autoincrement())
  merchantId      Int
  consumerId      Int
  status          EntityStatus @default(active)
  suspendedAt     DateTime?
  archivedAt      DateTime?
  statusReason    String?
  statusUpdatedAt DateTime     @default(now())
  joinedAt        DateTime     @default(now())
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  consumer        Consumer     @relation(fields: [consumerId], references: [id])
  merchant        Merchant     @relation(fields: [merchantId], references: [id])

  @@unique([merchantId, consumerId])
  @@index([merchantId])
  @@index([consumerId])
}

model StoreConsumer {
  id              Int          @id @default(autoincrement())
  storeId         Int
  consumerId      Int
  status          EntityStatus @default(active)
  suspendedAt     DateTime?
  archivedAt      DateTime?
  statusReason    String?
  statusUpdatedAt DateTime     @default(now())
  associatedAt    DateTime     @default(now())
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  consumer        Consumer     @relation(fields: [consumerId], references: [id])
  store           Store        @relation(fields: [storeId], references: [id])

  @@unique([storeId, consumerId])
  @@index([storeId])
  @@index([consumerId])
}

model StoreQr {
  id         Int          @id @default(autoincrement())
  storeId    Int
  /// Put this token in the QR code payload (example: "pv:store:<token>")
  token      String       @unique
  expiresAt  DateTime?
  createdAt  DateTime     @default(now())
  merchantId Int
  status     EntityStatus @default(active)
  updatedAt  DateTime?    @updatedAt
  merchant   Merchant     @relation(fields: [merchantId], references: [id])
  store      Store        @relation(fields: [storeId], references: [id])
  visits     Visit[]

  @@index([storeId])
  @@index([merchantId])
  @@index([status])
}

model Visit {
  id         Int         @id @default(autoincrement())
  storeId    Int
  consumerId Int?
  qrId       Int?
  createdAt  DateTime    @default(now())
  merchantId Int
  metadata   Json?
  source     VisitSource @default(qr_scan)
  consumer   Consumer?   @relation(fields: [consumerId], references: [id], onDelete: Restrict)
  merchant   Merchant    @relation(fields: [merchantId], references: [id])
  qr         StoreQr?    @relation(fields: [qrId], references: [id], onDelete: Restrict)
  store      Store       @relation(fields: [storeId], references: [id])

  @@index([storeId, createdAt])
  @@index([consumerId, createdAt])
  @@index([merchantId, createdAt])
}

/**
 * ===============================
 * Billing domain (v2.02.1)
 * ===============================
 */

model BillingAccount {
  id Int @id @default(autoincrement())

  // 1:1 with Merchant
  merchantId Int      @unique
  merchant   Merchant @relation(fields: [merchantId], references: [id])

  // Provider abstraction (opaque IDs only)
  provider           BillingProvider @default(stripe)
  providerCustomerId String?         @db.VarChar(255)

  // Billing Contact (may be external)
  billingEmail        String  @db.VarChar(320)
  billingName         String? @db.VarChar(200)
  billingPhone        String? @db.VarChar(32)
  billingAddressJson  Json?
  policyOverridesJson Json?

  status BillingAccountStatus @default(active)

  paymentMethods PaymentMethod[]
  invoices       Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([providerCustomerId])
  @@index([status])
}

model PaymentMethod {
  id Int @id @default(autoincrement())

  billingAccountId Int
  billingAccount   BillingAccount @relation(fields: [billingAccountId], references: [id])

  // Provider abstraction (opaque ID)
  providerPaymentMethodId String @db.VarChar(255)

  // Safe display metadata only
  type     PaymentMethodType? @default(card)
  brand    String?            @db.VarChar(50)
  last4    String?            @db.VarChar(4)
  expMonth Int?
  expYear  Int?

  status PaymentMethodStatus @default(active)

  // Replacement chain:
  // Old methods point to the method that replaced them.
  // One "new" method may replace multiple old ones -> one-to-many.
  replacedById Int?
  replacedBy   PaymentMethod?  @relation("PMReplacedBy", fields: [replacedById], references: [id])
  replaces     PaymentMethod[] @relation("PMReplacedBy")

  // Opposite relation for Payment.paymentMethod
  payments Payment[]

  createdAt DateTime @default(now())

  @@unique([billingAccountId, providerPaymentMethodId])
  @@index([billingAccountId, status])
  @@index([providerPaymentMethodId])
}

model Invoice {
  id Int @id @default(autoincrement())

  billingAccountId Int
  billingAccount   BillingAccount @relation(fields: [billingAccountId], references: [id])

  // denormalized for admin queries
  merchantId Int
  merchant   Merchant @relation(fields: [merchantId], references: [id])

  externalInvoiceId String? @db.VarChar(255)

  periodStart  DateTime?
  periodEnd    DateTime?
  issuedAt     DateTime?
  netTermsDays Int?
  dueAt        DateTime?
  status       InvoiceStatus @default(draft)

  subtotalCents   Int @default(0)
  taxCents        Int @default(0)
  totalCents      Int @default(0)
  amountPaidCents Int @default(0)

  generationVersion Int @default(1)

  relatedToInvoiceId Int?
  relatedToInvoice   Invoice?  @relation("InvoiceRelated", fields: [relatedToInvoiceId], references: [id])
  relatedInvoices    Invoice[] @relation("InvoiceRelated")

  lineItems      InvoiceLineItem[]
  payments       Payment[]
  guestPayTokens GuestPayToken[]
  mailEvents     MailEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([merchantId, status])
  @@index([billingAccountId, status])
  @@index([externalInvoiceId])
  @@index([relatedToInvoiceId])
}

model InvoiceLineItem {
  id Int @id @default(autoincrement())

  invoiceId Int
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  description String @db.VarChar(500)
  quantity    Int    @default(1)

  unitPriceCents Int?
  amountCents    Int

  sourceType  InvoiceLineSourceType
  sourceRefId String?               @db.VarChar(255)

  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@index([sourceType, sourceRefId])
}

model Payment {
  id Int @id @default(autoincrement())

  invoiceId Int
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  amountCents Int
  status      PaymentStatus @default(pending)

  providerChargeId String? @db.VarChar(255)
  payerEmail       String? @db.VarChar(320)

  paymentMethodId Int?
  paymentMethod   PaymentMethod? @relation(fields: [paymentMethodId], references: [id])

  mailEvents MailEvent[]

  createdAt       DateTime @default(now())
  statusUpdatedAt DateTime @default(now())

  @@index([invoiceId, status])
  @@index([providerChargeId])
}

model GuestPayToken {
  id Int @id @default(autoincrement())

  invoiceId Int
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  tokenHash String    @unique @db.VarChar(255)
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@index([expiresAt])
}

/**
 * ===============================
 * Mail domain (Mail-Flow-1)
 * ===============================
 */

model MailEvent {
  id Int @id @default(autoincrement())

  // Classification
  category    String          @db.VarChar(80)
  triggerType MailTriggerType

  // Idempotency: auto sends must set this. manual sends may leave null.
  idempotencyKey String? @db.VarChar(255)

  // Optional linkages
  invoiceId Int?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  paymentId Int?
  payment   Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  // Who initiated (system has null actorUserId)
  actorRole   String @db.VarChar(40)
  actorUserId Int?
  actorUser   User?  @relation("MailEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  // Mail content + addressing
  template String @db.VarChar(120)
  toEmail  String @db.VarChar(320)

  // Outcome
  status            MailEventStatus @default(failed)
  error             String?
  transport         String?         @db.VarChar(40)
  providerMessageId String?         @db.VarChar(255)

  createdAt DateTime  @default(now())
  sentAt    DateTime?

  // Uniqueness: allows multiple NULL idempotencyKey values (Postgres)
  @@unique([triggerType, idempotencyKey])
  @@index([category])
  @@index([invoiceId])
  @@index([paymentId])
  @@index([actorUserId])
  @@index([createdAt])
}

/**
 * ===============================
 * Existing enums
 * ===============================
 */

enum EntityStatus {
  active
  suspended
  archived
}

enum SystemRole {
  /// PerkValet global admin (routes to /admin)
  pv_admin

  /// PerkValet platform AR clerk (routes to /admin with AR-only nav)
  pv_ar_clerk

  /// PerkValet platform support (read-only org visibility)
  pv_support

  /// PerkValet QA role (non-production only)
  pv_qa

  /// Normal user (merchant-scoped roles apply via MerchantUser / StoreUser)
  user
}

enum PvDepartment {
  IT
  FINANCE
  SUPPORT
  EXECUTIVE
  OTHER
}

enum MerchantRole {
  owner
  merchant_admin
  merchant_ap_clerk
  store_admin
  pos_employee
}

enum StorePermissionLevel {
  admin
  subadmin
}

enum VisitSource {
  qr_scan
  manual
  import
}

/**
 * ===============================
 * Billing enums (v2.02.1)
 * ===============================
 */

enum BillingProvider {
  stripe
  manual
}

enum BillingAccountStatus {
  active
  suspended
  canceled
}

enum PaymentMethodType {
  card
  bank_account
  other
}

enum PaymentMethodStatus {
  active
  replaced
  expired
}

enum InvoiceStatus {
  draft
  issued
  past_due
  paid
  void
}

enum InvoiceLineSourceType {
  platform_fee
  usage_fee
  late_fee
  adjustment
}

enum PaymentStatus {
  pending
  succeeded
  failed
  refunded
}

/**
 * ===============================
 * Mail enums (Mail-Flow-1)
 * ===============================
 */

enum MailTriggerType {
  auto
  manual
}

enum MailEventStatus {
  sent
  failed
}
