/// ============================================================================
/// MODULE: perkvalet-schema-v2.00-role-permission-alignment
/// PURPOSE: Align MerchantRole and StorePermissionLevel with v2.00 contract
/// AUTHOR: ChatGPT + Frank Careccia
/// DATE: 2026-03-21
/// NOTES:
/// - Introduces POS access as a Store-level permission
/// - Removes store roles from MerchantRole
/// - Prepares system for clean POS authorization model
/// ============================================================================

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id    Int    @id @default(autoincrement())
  email String @unique

  /// For web login. Store a bcrypt/argon2 hash (never plaintext).
  passwordHash String

  /// Global role used to route after login (Option 1).
  systemRole SystemRole @default(user)

  /// ===============================
  /// Identity (person-level)
  /// ===============================
  firstName    String?
  lastName     String?
  phoneRaw     String?
  phoneE164    String? @db.VarChar(20)
  phoneCountry String  @default("US")

  tokenVersion      Int                  @default(0)
  passwordUpdatedAt DateTime?
  resetTokens       PasswordResetToken[]

  createdAt DateTime     @default(now())
  status    EntityStatus @default(active)
  updatedAt DateTime     @updatedAt

  merchantUsers      MerchantUser[]
  grantedRedemptions PromoRedemption[] @relation("GrantedByUser")
}

model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  tokenHash String    @unique @db.VarChar(255)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Merchant {
  id                Int                @id @default(autoincrement())
  name              String
  merchantType      String?            // coffee_shop | restaurant | fitness | salon_spa | retail | grocery | pet_services | automotive | specialty_food | education_kids
  status            EntityStatus       @default(active)
  suspendedAt       DateTime?
  archivedAt        DateTime?
  statusReason      String?
  statusUpdatedAt   DateTime           @default(now())
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  merchantConsumers MerchantConsumer[]
  merchantUsers     MerchantUser[]
  stores            Store[]
  qrs               StoreQr[]
  visits            Visit[]

  // Billing (v2.02.1)
  billingAccount BillingAccount?
  invoices       Invoice[] // <-- required opposite of Invoice.merchant

  // Catalog (E.2)
  products          Product[]
  productCategories ProductCategory[]
  bundles           Bundle[]

  // Promotions & Loyalty (Thread E)
  promoItems       PromoItem[]
  promotions       Promotion[]
  offerSets        OfferSet[]
  consumerProgress ConsumerPromoProgress[]

  @@index([status])

  posConnections PosConnection[]
  posOrders      PosOrder[]

  // Growth Advisor — Promotion Outcomes
  promotionEvents    PromotionEvent[]
  baselineSnapshots  PromotionBaselineSnapshot[]
  promotionOutcomes  PromotionOutcome[]

  // Payment Event Ledger
  paymentEvents      PaymentEvent[]

  // CPG & Settlement
  cpgParticipations  CpgParticipation[]
  settlementAccruals SettlementAccrual[]

  // Duplicate customer alerts
  duplicateCustomerAlerts DuplicateCustomerAlert[]

  // Clover reward discounts
  rewardDiscounts PosRewardDiscount[]

  // Consumer check-ins
  checkins ConsumerCheckin[]

  // Seed data (staging only)
  isSeedMerchant    Boolean @default(false)
  seedBaselineDaily Int     @default(80)

  // Simulator — average transaction value (cents). Updated monthly from POS data.
  avgTransactionValueCents Int?

  // Reporting summaries
  dailySummaries          MerchantDailySummary[]
  promotionDailySummaries PromotionDailySummary[]
  engagementSummaries     ConsumerEngagementSummary[]

  // Onboarding
  onboardingSession OnboardingSession?

  // AI Support
  supportTickets SupportTicket[]
}

model Store {
  id       Int     @id @default(autoincrement())
  name     String
  address1 String?
  city     String?
  state    String?
  postal   String?

  /// ===============================
  /// Store phones (location-level)
  /// ===============================
  /// Public store phone (required in V1 UI)
  phoneRaw     String
  phoneE164    String? @db.VarChar(20)
  phoneCountry String  @default("US")

  /// Back-office phone (optional)
  backOfficePhoneRaw     String?
  backOfficePhoneE164    String? @db.VarChar(20)
  backOfficePhoneCountry String  @default("US")

  /// ===============================
  /// Store primary contact (assigned employee)
  /// ===============================
  primaryContactStoreUserId Int?
  primaryContactStoreUser   StoreUser? @relation("StorePrimaryContact", fields: [primaryContactStoreUserId], references: [id])

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  archivedAt      DateTime?
  merchantId      Int
  status          EntityStatus @default(active)
  statusReason    String?
  statusUpdatedAt DateTime     @default(now())
  suspendedAt     DateTime?
  merchant        Merchant     @relation(fields: [merchantId], references: [id])

  storeConsumers StoreConsumer[]
  qrs            StoreQr[]
  storeUsers     StoreUser[]
  visits         Visit[]

  /// POS session inactivity timeout — configurable per store (minutes, default 5)
  posSessionTimeoutMinutes Int @default(5)

  // Catalog — store-level product overrides
  storeProducts StoreProduct[]

  // Promotions & Loyalty (Thread E)
  offerSetStores      OfferSetStore[]
  grantedRedemptions  PromoRedemption[] @relation("RedemptionGrantStore")
  posOrders           PosOrder[]

  // Payment Event Ledger
  paymentEvents       PaymentEvent[] @relation("PaymentEventStore")

  // Geofencing
  latitude             Float?
  longitude            Float?
  geofenceRadiusMeters Int      @default(150) // 50-500, merchant-configurable

  // Discover
  discoverability      Boolean  @default(true)  // Merchant opt-out from Discover screen
  category             String?  @db.VarChar(32) // cafe, salon, retail, auto, pet, restaurant, other
  logoUrl              String?  @db.VarChar(500)
  hoursJson            String?  @db.Text        // JSON: { mon: "7am-6pm", tue: "7am-6pm", ... }

  // Consumer check-ins
  checkins ConsumerCheckin[]

  // Store-specific promotions
  storePromotions Promotion[] @relation("StorePromotions")

  // Reporting summaries
  dailySummaries      MerchantDailySummary[]
  engagementSummaries ConsumerEngagementSummary[]

  @@index([merchantId])
  @@index([phoneE164])
  @@index([backOfficePhoneE164])
  @@index([primaryContactStoreUserId])
  @@index([status])
}

model MerchantUser {
  id              Int          @id @default(autoincrement())
  merchantId      Int
  userId          Int
  role            MerchantRole
  status          EntityStatus @default(active)
  suspendedAt     DateTime?
  archivedAt      DateTime?
  statusReason    String?
  statusUpdatedAt DateTime     @default(now())
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  merchant        Merchant     @relation(fields: [merchantId], references: [id])
  user            User         @relation(fields: [userId], references: [id])
  storeUsers      StoreUser[]

  @@unique([merchantId, userId])
  @@index([merchantId])
  @@index([userId])
}

model StoreUser {
  id              Int                  @id @default(autoincrement())
  storeId         Int
  merchantUserId  Int
  permissionLevel StorePermissionLevel @default(store_admin)
  status          EntityStatus         @default(active)
  suspendedAt     DateTime?
  archivedAt      DateTime?
  statusReason    String?
  statusUpdatedAt DateTime             @default(now())
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  merchantUser    MerchantUser         @relation(fields: [merchantUserId], references: [id])
  store           Store                @relation(fields: [storeId], references: [id])

  /// Stores where this StoreUser is set as the primary contact
  primaryContactForStores Store[] @relation("StorePrimaryContact")

  @@unique([storeId, merchantUserId])
  @@index([storeId])
  @@index([merchantUserId])
}

model Consumer {
  id                Int                @id @default(autoincrement())
  /// Consumers can share an email address (NOT unique).
  email             String?
  firstName         String?
  lastName          String?
  phoneRaw          String?
  phoneE164         String?            @unique @db.VarChar(20)
  phoneCountry      String             @default("US")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  archivedAt        DateTime?
  status            EntityStatus       @default(active)
  suspendedAt       DateTime?
  phones            ConsumerPhone[]
  merchantConsumers MerchantConsumer[]
  storeConsumers    StoreConsumer[]
  visits            Visit[]

  // Promotions & Loyalty (Thread E)
  promoProgress ConsumerPromoProgress[]
  redemptions   PromoRedemption[]

  // Entitlements (Thread 1)
  entitlements Entitlement[]

  posOrders        PosOrder[]
  giftCards        ConsumerGiftCard[]
  rewardDiscounts  PosRewardDiscount[]
  checkins         ConsumerCheckin[]

  // Seed data
  isSeedConsumer   Boolean @default(false)
  seedMerchantId   Int?

  @@index([email])
  @@index([phoneE164])
  @@index([status])
}

model ConsumerOtpToken {
  id         Int       @id @default(autoincrement())
  phoneE164  String    @db.VarChar(20)
  code       String    @db.VarChar(6)
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([phoneE164])
}

model ConsumerPhone {
  id         Int          @id @default(autoincrement())
  consumerId Int
  phoneE164  String       @unique @db.VarChar(20)
  isPrimary  Boolean      @default(false)
  verifiedAt DateTime?
  status     EntityStatus @default(active)
  archivedAt DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  consumer   Consumer     @relation(fields: [consumerId], references: [id])

  @@index([consumerId])
  @@index([isPrimary])
}

model MerchantConsumer {
  id              Int          @id @default(autoincrement())
  merchantId      Int
  consumerId      Int
  status          EntityStatus @default(active)
  suspendedAt     DateTime?
  archivedAt      DateTime?
  statusReason    String?
  statusUpdatedAt DateTime     @default(now())
  joinedAt        DateTime     @default(now())
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  consumer        Consumer     @relation(fields: [consumerId], references: [id])
  merchant        Merchant     @relation(fields: [merchantId], references: [id])

  @@unique([merchantId, consumerId])
  @@index([merchantId])
  @@index([consumerId])
}

model StoreConsumer {
  id              Int          @id @default(autoincrement())
  storeId         Int
  consumerId      Int
  status          EntityStatus @default(active)
  suspendedAt     DateTime?
  archivedAt      DateTime?
  statusReason    String?
  statusUpdatedAt DateTime     @default(now())
  associatedAt    DateTime     @default(now())
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  consumer        Consumer     @relation(fields: [consumerId], references: [id])
  store           Store        @relation(fields: [storeId], references: [id])

  @@unique([storeId, consumerId])
  @@index([storeId])
  @@index([consumerId])
}

model StoreQr {
  id         Int          @id @default(autoincrement())
  storeId    Int
  /// Put this token in the QR code payload (example: "pv:store:<token>")
  token      String       @unique
  expiresAt  DateTime?
  createdAt  DateTime     @default(now())
  merchantId Int
  status     EntityStatus @default(active)
  updatedAt  DateTime?    @updatedAt
  merchant   Merchant     @relation(fields: [merchantId], references: [id])
  store      Store        @relation(fields: [storeId], references: [id])
  visits     Visit[]

  @@index([storeId])
  @@index([merchantId])
  @@index([status])
}

model Visit {
  id         Int         @id @default(autoincrement())
  storeId    Int
  consumerId Int?
  qrId       Int?
  createdAt  DateTime    @default(now())
  merchantId Int
  metadata   Json?
  source     VisitSource @default(qr_scan)
  consumer   Consumer?   @relation(fields: [consumerId], references: [id], onDelete: Restrict)
  merchant   Merchant    @relation(fields: [merchantId], references: [id])
  qr         StoreQr?    @relation(fields: [qrId], references: [id], onDelete: Restrict)
  store      Store       @relation(fields: [storeId], references: [id])

  // Seed data flag
  isSeedData        Boolean @default(false)

  // POS-5A extensions (additive, safe)
  posVisitId        String? @unique @db.VarChar(64)
  posEventId        String? @db.VarChar(64)
  posIdempotencyKey String? @unique @db.VarChar(128)
  posIdentifier     String? @db.VarChar(320)

  // Visit lifecycle (Thread 1)
  status          VisitStatus @default(pending_identity)
  associateUserId Int?
  sessionId       String?     @db.VarChar(128)

  posOrder PosOrder?

  @@index([storeId, createdAt])
  @@index([consumerId, createdAt])
  @@index([merchantId, createdAt])
  @@index([posVisitId])
  @@index([posIdempotencyKey])
  @@index([status, merchantId])
}

model PosReward {
  // POS reward id is the stable external id: rew_<ulid>
  id String @id @db.VarChar(64)

  // Optional correlation to POS visit id (vis_<ulid>)
  posVisitId String? @db.VarChar(64)

  eventId        String? @db.VarChar(64)
  idempotencyKey String  @unique @db.VarChar(128)

  merchantId Int
  storeId    Int
  userId     Int

  identifier  String   @db.VarChar(320)
  payloadJson Json?
  createdAt   DateTime @default(now())

  @@index([merchantId, storeId, createdAt])
  @@index([posVisitId])
}

/**
 * ===============================
 * EventLog — append-only audit ledger (Thread 1)
 * ===============================
 */

model EventLog {
  id               Int      @id @default(autoincrement())
  eventType        String   @db.VarChar(100)
  merchantId       Int
  storeId          Int
  consumerId       Int?
  ownerConsumerId  Int?
  visitId          Int?
  entitlementId    Int?
  bundleInstanceId Int?
  associateUserId  Int?
  sessionId        String?  @db.VarChar(128)
  source           String   @db.VarChar(50)
  outcome          String?  @db.VarChar(50)
  payloadJson      Json?
  createdAt        DateTime @default(now())

  @@index([merchantId, storeId, createdAt])
  @@index([consumerId, createdAt])
  @@index([visitId])
  @@index([eventType, createdAt])
  @@index([associateUserId, createdAt])
}

/**
 * ===============================
 * Entitlement — unified output layer (Thread 1)
 * ===============================
 */

model Entitlement {
  id           Int               @id @default(autoincrement())
  consumerId   Int
  merchantId   Int
  storeId      Int?
  type         EntitlementType
  sourceId     Int
  status       EntitlementStatus @default(active)
  validFrom    DateTime?
  expiresAt    DateTime?
  metadataJson Json?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  redeemedAt   DateTime?

  consumer Consumer @relation(fields: [consumerId], references: [id])

  @@index([consumerId, merchantId])
  @@index([consumerId, status])
  @@index([merchantId, storeId, createdAt])
  @@index([type, status])
}

/**
 * ===============================
 * Billing domain (v2.02.1)
 * ===============================
 */

model BillingAccount {
  id Int @id @default(autoincrement())

  // 1:1 with Merchant
  merchantId Int      @unique
  merchant   Merchant @relation(fields: [merchantId], references: [id])

  // Provider abstraction (opaque IDs only)
  provider           BillingProvider @default(stripe)
  providerCustomerId String?         @db.VarChar(255)

  // PV-assigned account number (admin only)
  pvAccountNumber String? @unique @db.VarChar(50)

  // Billing Contact (may be external)
  billingEmail    String  @db.VarChar(320)
  billingName     String? @db.VarChar(200)
  billingPhone    String? @db.VarChar(32)

  // Billing Address (flat fields — replaces billingAddressJson)
  billingAddress1 String? @db.VarChar(200)
  billingCity     String? @db.VarChar(100)
  billingState    String? @db.VarChar(50)
  billingPostal   String? @db.VarChar(20)

  policyOverridesJson Json?

  status BillingAccountStatus @default(active)

  paymentMethods PaymentMethod[]
  invoices       Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([providerCustomerId])
  @@index([status])
}

model PaymentMethod {
  id Int @id @default(autoincrement())

  billingAccountId Int
  billingAccount   BillingAccount @relation(fields: [billingAccountId], references: [id])

  // Provider abstraction (opaque ID)
  providerPaymentMethodId String @db.VarChar(255)

  // Safe display metadata only
  type     PaymentMethodType? @default(card)
  brand    String?            @db.VarChar(50)
  last4    String?            @db.VarChar(4)
  expMonth Int?
  expYear  Int?

  status PaymentMethodStatus @default(active)

  // Replacement chain:
  // Old methods point to the method that replaced them.
  // One "new" method may replace multiple old ones -> one-to-many.
  replacedById Int?
  replacedBy   PaymentMethod?  @relation("PMReplacedBy", fields: [replacedById], references: [id])
  replaces     PaymentMethod[] @relation("PMReplacedBy")

  // Opposite relation for Payment.paymentMethod
  payments Payment[]

  createdAt DateTime @default(now())

  @@unique([billingAccountId, providerPaymentMethodId])
  @@index([billingAccountId, status])
  @@index([providerPaymentMethodId])
}

model Invoice {
  id Int @id @default(autoincrement())

  billingAccountId Int
  billingAccount   BillingAccount @relation(fields: [billingAccountId], references: [id])

  // denormalized for admin queries
  merchantId Int
  merchant   Merchant @relation(fields: [merchantId], references: [id])

  externalInvoiceId String? @db.VarChar(255)

  periodStart  DateTime?
  periodEnd    DateTime?
  issuedAt     DateTime?
  netTermsDays Int?
  dueAt        DateTime?
  status       InvoiceStatus @default(draft)

  subtotalCents   Int @default(0)
  taxCents        Int @default(0)
  totalCents      Int @default(0)
  amountPaidCents Int @default(0)

  generationVersion Int @default(1)

  relatedToInvoiceId Int?
  relatedToInvoice   Invoice?  @relation("InvoiceRelated", fields: [relatedToInvoiceId], references: [id])
  relatedInvoices    Invoice[] @relation("InvoiceRelated")

  lineItems      InvoiceLineItem[]
  payments       Payment[]
  guestPayTokens GuestPayToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([merchantId, status])
  @@index([billingAccountId, status])
  @@index([externalInvoiceId])
  @@index([relatedToInvoiceId])
}

model InvoiceLineItem {
  id Int @id @default(autoincrement())

  invoiceId Int
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  description String @db.VarChar(500)
  quantity    Int    @default(1)

  unitPriceCents Int?
  amountCents    Int

  sourceType  InvoiceLineSourceType
  sourceRefId String?               @db.VarChar(255)

  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@index([sourceType, sourceRefId])
}

model Payment {
  id Int @id @default(autoincrement())

  invoiceId Int
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  amountCents Int
  status      PaymentStatus @default(pending)

  providerChargeId String? @db.VarChar(255)
  payerEmail       String? @db.VarChar(320)

  paymentMethodId Int?
  paymentMethod   PaymentMethod? @relation(fields: [paymentMethodId], references: [id])

  createdAt       DateTime @default(now())
  statusUpdatedAt DateTime @default(now())

  @@index([invoiceId, status])
  @@index([providerChargeId])
}

model GuestPayToken {
  id Int @id @default(autoincrement())

  invoiceId Int
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  tokenHash String    @unique @db.VarChar(255)
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@index([expiresAt])
}

/**
 * ===============================
 * Existing enums
 * ===============================
 */

enum EntityStatus {
  staging
  active
  suspended
  archived
}

enum SystemRole {
  /// PerkValet global admin (routes to /admin)
  pv_admin

  /// Normal user (merchant-scoped roles apply via MerchantUser / StoreUser)
  user
}

enum MerchantRole {
  owner
  merchant_admin
  ap_clerk
  merchant_employee
}

enum StorePermissionLevel {
  store_admin
  store_subadmin
  pos_access
}

enum VisitSource {
  qr_scan
  manual
  import
  pos_integrated
  square_webhook
  clover_webhook
  toast_webhook
  web
}

/**
 * ===============================
 * Billing enums (v2.02.1)
 * ===============================
 */

enum BillingProvider {
  stripe
  manual
}

enum BillingAccountStatus {
  active
  suspended
  canceled
}

enum PaymentMethodType {
  card
  bank_account
  other
}

enum PaymentMethodStatus {
  active
  replaced
  expired
}

enum InvoiceStatus {
  draft
  issued
  past_due
  paid
  void
}

enum InvoiceLineSourceType {
  platform_fee
  usage_fee
  late_fee
  adjustment
}

enum PaymentStatus {
  pending
  succeeded
  failed
  refunded
}

/**
 * ===============================
 * Catalog (E.2)
 * ===============================
 */

model Product {
  id          Int           @id @default(autoincrement())
  merchantId  Int
  merchant    Merchant      @relation(fields: [merchantId], references: [id])

  // SKU: stable identity — never changes even if name changes or product is reactivated.
  // Auto-generated as PRD-0001, PRD-0002, ... if not provided by merchant.
  sku         String        @db.VarChar(100)

  name        String        @db.VarChar(200)
  description String?       @db.VarChar(1000)
  imageUrl    String?       @db.VarChar(2048)
  /// AI-generated (and merchant-editable) compliance blurb: product description + allergen/dietary statement.
  complianceText String?    @db.Text
  status      ProductStatus @default(draft)

  // POS catalog sync
  catalogSource     String?  @default("native") @db.VarChar(16) // native | pos
  externalCatalogId String?  @db.VarChar(128)  // POS-specific item ID
  posConnectionId   Int?
  posConnection     PosConnection? @relation(fields: [posConnectionId], references: [id])
  upc               String?  @db.VarChar(14)   // UPC-A, UPC-E, EAN-13, GTIN-14
  priceCents        Int?                        // base price in cents

  // Category (v3.5 model — required for reward qualification)
  categoryId  Int?
  category    ProductCategory? @relation(fields: [categoryId], references: [id])

  startAt          DateTime?
  endAt            DateTime?
  timeframeDays    Int?
  /// Set once when product first transitions to active. Never reset on deactivate/reactivate.
  firstActivatedAt DateTime?

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  storeProducts StoreProduct[]

  @@unique([merchantId, sku])
  @@index([merchantId, status])
  @@index([categoryId])
  @@index([externalCatalogId])
  @@index([posConnectionId])
}

enum ProductStatus {
  draft
  active
  inactive
}

/**
 * ===============================
 * Product Categories (v3.5)
 * ===============================
 * Groups products into rewardable units.
 * Product → Category → Reward Program (v1).
 * One category per product, no hierarchy.
 */

model ProductCategory {
  id         Int           @id @default(autoincrement())
  merchantId Int
  merchant   Merchant      @relation(fields: [merchantId], references: [id])

  name         String              @db.VarChar(200)
  status       ProductStatus       @default(active)
  /// "standard" = purchase-based; "visit" = any identified store visit qualifies.
  /// Each merchant has exactly one visit-type category (auto-created, protected from deletion).
  categoryType ProductCategoryType @default(standard)

  // POS catalog sync
  catalogSource     String?  @default("native") @db.VarChar(16) // native | pos
  externalCatalogId String?  @db.VarChar(128)  // POS-specific category ID

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products   Product[]
  promotions Promotion[]

  @@index([merchantId, status])
  @@index([merchantId, categoryType])
  @@index([externalCatalogId])
}

enum ProductCategoryType {
  standard
  visit
}

/**
 * ===============================
 * Store Product Overrides (v1)
 * ===============================
 * Controls which products are enabled at each store.
 * No row = product is available at all stores (opt-in disable model).
 * Stores can disable products; they cannot change category or create new products.
 * Used by POS grid generation and reward earn qualification.
 */

model StoreProduct {
  id         Int      @id @default(autoincrement())
  storeId    Int
  productId  Int
  /// true = product is available at this store; false = disabled
  enabled    Boolean  @default(true)
  updatedAt  DateTime @updatedAt

  store   Store   @relation(fields: [storeId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([storeId, productId])
  @@index([storeId, enabled])
  @@index([productId])
}

/**
 * ===============================
 * Promotions & Loyalty (Thread E)
 * ===============================
 */

// ── Enums ───────────────────────────────────────────────────────

enum PromoItemType {
  visit          // any store check-in
  any_purchase   // any purchase, regardless of product
  single_product // specific SKU required
  product_bundle // multiple SKUs required in same transaction
}

enum PromoMechanic {
  stamps // count qualifying events; threshold = milestone
  points // earnPerUnit points per event; redeem when balance >= threshold
}

enum PromoRewardType {
  free_item      // rewardSku references a Product.sku within this merchant
  discount_pct   // rewardValue = integer percent (1–100)
  discount_fixed // rewardValue = cents
  custom         // rewardNote describes the reward (e.g. "free upgrade")
}

enum OfferSetScope {
  merchant // applies across all stores of this merchant
  store    // applies only to stores listed in OfferSetStore
}

enum PromoStatus {
  active
  paused
  archived
}

/// Promotion (earn rule) publication lifecycle — mirrors BundleStatus.
/// draft → staged → active → paused → archived
enum PromotionStatus {
  draft      // Being configured; not visible to earn engine or consumers
  staged     // startAt set; scheduled; visible to admins only
  active     // Running; consumers can earn stamps
  paused     // Temporarily halted; progress preserved
  archived   // Ended; never deleted; can be duplicated as new draft
}

enum OfferSetStatus {
  draft
  active
  expired
  archived
}

enum RedemptionStatus {
  pending   // consumer confirmed intent; redemptionToken issued, awaiting POS grant
  granted   // POS employee (or integration) confirmed the reward
  cancelled // voided before grant
  expired   // redemptionToken lapsed before POS acted
}

// ── Layer 1: PromoItem ──────────────────────────────────────────

/// A trackable action that earns progress toward a Promotion.
model PromoItem {
  id          Int           @id @default(autoincrement())
  merchantId  Int
  name        String        @db.VarChar(200)
  description String?       @db.VarChar(1000)
  type        PromoItemType
  status      PromoStatus   @default(active)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  merchant   Merchant        @relation(fields: [merchantId], references: [id])
  skus       PromoItemSku[]
  promotions PromotionItem[]

  @@index([merchantId, status])
}

/// SKUs that qualify for a PromoItem.
/// single_product = 1 row; product_bundle = N rows (all must appear in transaction).
model PromoItemSku {
  id          Int    @id @default(autoincrement())
  promoItemId Int
  /// References Product.sku within the same merchant (stable string ref, not FK).
  sku         String @db.VarChar(100)
  /// Minimum quantity of this SKU required per transaction (usually 1).
  quantity    Int    @default(1)

  promoItem PromoItem @relation(fields: [promoItemId], references: [id])

  @@unique([promoItemId, sku])
  @@index([promoItemId])
}

// ── Layer 2: Promotion ──────────────────────────────────────────

/// An earn + reward rule. Consumers accumulate progress via qualifying PromoItems.
model Promotion {
  id          Int     @id @default(autoincrement())
  merchantId  Int
  name        String  @db.VarChar(200)
  description String? @db.VarChar(1000)

  // v3.5 qualifying category (category-based earn model).
  // When set, any purchase of a product in this category earns progress.
  // null = uses PromoItem linkage (v2 model).
  categoryId  Int?
  category    ProductCategory? @relation(fields: [categoryId], references: [id])

  // Earn mechanic
  mechanic    PromoMechanic
  /// Points per qualifying event (points mechanic). Always 1 for stamps.
  earnPerUnit Int           @default(1)
  /// Stamps or points needed to earn one reward grant.
  threshold   Int
  /// Max reward grants per visit/session. null = unlimited (merchant decides).
  maxGrantsPerVisit Int?

  // Timeframe (v3.5): rolling earn window in days.
  // e.g. 30 = progress earned more than 30 days ago does not count.
  // null = no expiry window (progress never resets by time).
  timeframeDays Int?

  /// Promotion type for simulator context: stamp | bundle | tiered | conditional | referral
  promotionType String  @default("stamp") @db.VarChar(20)

  /// Growth Studio objective: bring-back | grow-base | drive-revenue | fill-slow | reward-best
  objective     String? @db.VarChar(30)

  // Reward definition
  rewardType  PromoRewardType
  /// discount_pct: 1–100; discount_fixed: cents; null for free_item/custom.
  rewardValue Int?
  /// free_item only: Product.sku (within this merchant) awarded on grant.
  rewardSku   String? @db.VarChar(100)
  /// custom only: human-readable reward description for consumer and POS.
  rewardNote  String? @db.VarChar(500)

  /// AI-generated (and merchant-editable) terms & conditions shown to consumers in the detail view.
  legalText   String? @db.Text

  /// If true, stamp card resets after each reward and consumer keeps earning.
  /// If false, consumer earns one reward and stamps stop accumulating.
  repeatable       Boolean @default(true)

  /// Store-specific promotion: null = merchant-wide (all stores), populated = this store only.
  storeId          Int?
  store            Store?  @relation("StorePromotions", fields: [storeId], references: [id])

  /// Days after earning before reward expires. Platform minimum: 30.
  rewardExpiryDays Int     @default(90)

  // Lifecycle
  status           PromotionStatus @default(draft)
  startAt          DateTime?
  endAt            DateTime?
  /// Set once when status first transitions to active. Never reset on pause/resume.
  firstActivatedAt DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  merchant    Merchant                @relation(fields: [merchantId], references: [id])
  items       PromotionItem[]
  offerSets   OfferSetPromotion[]
  progress    ConsumerPromoProgress[]
  redemptions PromoRedemption[]
  auditLogs   PromoAuditLog[]

  // Growth Advisor — Promotion Outcomes
  promotionEvents    PromotionEvent[]
  baselineSnapshots  PromotionBaselineSnapshot[]
  outcomes           PromotionOutcome[]

  // Reporting summaries
  dailySummaries PromotionDailySummary[]

  // Advanced promotion types
  tiers            PromotionTier[]
  conditions       PromotionCondition[]
  referralCodes    ReferralCode[]
  bundleDefinition BundleDefinition?

  @@index([merchantId, status])
}

/// Tiered reward levels for tiered promotions.
/// Each tier has its own threshold and reward. Consumer progresses through tiers
/// as lifetime visits accumulate. Tier status is permanent — never resets.
model PromotionTier {
  id            Int    @id @default(autoincrement())
  promotionId   Int
  promotion     Promotion @relation(fields: [promotionId], references: [id])
  tierName      String @db.VarChar(50)  // "Bronze", "Silver", "Gold"
  tierLevel     Int    // 1, 2, 3 — ordering
  threshold     Int    // lifetime visits to reach this tier
  rewardType    String @db.VarChar(20)  // discount_fixed, discount_pct, free_item, custom
  rewardValue   Int?   // cents for discount_fixed, percent for discount_pct
  rewardNote    String? @db.VarChar(500) // description for free_item or custom

  @@unique([promotionId, tierLevel])
  @@index([promotionId])
}

/// Conditional modifiers for promotions.
/// These don't compete — they multiply the winning promo's stamp award.
/// Sub-types: time (day/hour window), lapse (win-back), spend (minimum order).
model PromotionCondition {
  id              Int    @id @default(autoincrement())
  promotionId     Int
  promotion       Promotion @relation(fields: [promotionId], references: [id])
  conditionType   String @db.VarChar(20) // "time", "lapse", "spend"

  // Time-based: bonus during specific days/hours
  activeDays      Json?  // ["mon","tue","wed"] or null for all days
  activeStartHour Int?   // 0-23, e.g. 14 = 2pm
  activeEndHour   Int?   // 0-23, e.g. 17 = 5pm

  // Lapse-based: win-back after N days inactive
  lapseDays       Int?   // days of inactivity to trigger

  // Spend-based: minimum order value
  minimumSpendCents Int? // minimum order total

  // Reward: multiplier (most common) or instant reward
  bonusMultiplier Float  @default(2.0) // 2x, 3x stamps
  bonusLabel      String? @db.VarChar(100) // "Tuesday afternoon bonus", "Welcome back"

  createdAt       DateTime @default(now())

  @@index([promotionId])
}

/// Bundle promotion definition — which items are in the bundle and pricing.
/// Items stored as JSON array: [{ sku, name, quantity }]
model BundleDefinition {
  id               Int       @id @default(autoincrement())
  promotionId      Int       @unique
  promotion        Promotion @relation(fields: [promotionId], references: [id])
  items            Json      // [{ sku: "LATTE", name: "Latte", quantity: 1 }, ...]
  bundlePriceCents Int       // what the consumer pays for the complete bundle
  savingsCents     Int       // how much they save vs individual prices
  validityDays     Int       @default(30) // days to complete the bundle
  createdAt        DateTime  @default(now())
}

/// Tracks per-consumer bundle completion progress.
/// checkedItems is a JSON array of item SKUs that have been purchased.
model BundleProgress {
  id            Int      @id @default(autoincrement())
  consumerId    Int
  promotionId   Int
  merchantId    Int
  checkedItems  Json     @default("[]") // ["LATTE", "MUFFIN"] — items purchased so far
  complete      Boolean  @default(false)
  startedAt     DateTime @default(now())
  completedAt   DateTime?

  @@unique([consumerId, promotionId])
  @@index([consumerId])
  @@index([promotionId])
  @@index([merchantId])
}

/// Referral code — unique per consumer per referral promotion.
/// Referrer shares code, referee uses it at signup or first visit.
/// Both get rewarded when referee makes first purchase.
model ReferralCode {
  id            Int      @id @default(autoincrement())
  promotionId   Int
  promotion     Promotion @relation(fields: [promotionId], references: [id])
  consumerId    Int      // the referrer
  code          String   @unique @db.VarChar(20) // e.g. "JANE-BLVD-X7K2"
  usedCount     Int      @default(0)
  maxUses       Int      @default(10) // cap per referrer
  createdAt     DateTime @default(now())

  redemptions   ReferralRedemption[]

  @@index([consumerId])
  @@index([promotionId])
}

/// Tracks each successful referral — one row per referee.
model ReferralRedemption {
  id              Int      @id @default(autoincrement())
  referralCodeId  Int
  referralCode    ReferralCode @relation(fields: [referralCodeId], references: [id])
  referrerId      Int      // who referred
  refereeId       Int      // who was referred
  merchantId      Int
  firstPurchaseAt DateTime? // when referee made first purchase (triggers rewards)
  referrerRewarded Boolean @default(false)
  refereeRewarded  Boolean @default(false)
  createdAt       DateTime @default(now())

  @@unique([referralCodeId, refereeId])
  @@index([referralCodeId])
  @@index([refereeId])
  @@index([merchantId])
}

/// Junction: which PromoItems trigger a Promotion.
model PromotionItem {
  promotionId Int
  promoItemId Int

  promotion Promotion @relation(fields: [promotionId], references: [id])
  promoItem PromoItem @relation(fields: [promoItemId], references: [id])

  @@id([promotionId, promoItemId])
}

// ── Layer 3: OfferSet ───────────────────────────────────────────

/// A published bundle of Promotions with a stable QR token.
model OfferSet {
  id          Int            @id @default(autoincrement())
  merchantId  Int
  name        String         @db.VarChar(200)
  description String?        @db.VarChar(1000)
  /// Embedded in QR payload: pv:store:<storeToken>:offers:<token>:v1:<sig>
  token       String         @unique @db.VarChar(64)
  scope       OfferSetScope  @default(merchant)
  status      OfferSetStatus @default(draft)
  startAt     DateTime?
  endAt       DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  merchant   Merchant            @relation(fields: [merchantId], references: [id])
  promotions OfferSetPromotion[]
  stores     OfferSetStore[]

  @@index([merchantId, status])
  @@index([token])
}

/// Junction: Promotions included in an OfferSet, with display order.
model OfferSetPromotion {
  offerSetId  Int
  promotionId Int
  sortOrder   Int @default(0)

  offerSet  OfferSet  @relation(fields: [offerSetId], references: [id])
  promotion Promotion @relation(fields: [promotionId], references: [id])

  @@id([offerSetId, promotionId])
  @@index([offerSetId, sortOrder])
}

/// Junction: Stores included when OfferSet.scope = store.
model OfferSetStore {
  offerSetId Int
  storeId    Int

  offerSet OfferSet @relation(fields: [offerSetId], references: [id])
  store    Store    @relation(fields: [storeId], references: [id])

  @@id([offerSetId, storeId])
}

// ── Layer 4: Consumer Progress ──────────────────────────────────

/// Running progress for one Consumer on one Promotion.
model ConsumerPromoProgress {
  id          Int @id @default(autoincrement())
  consumerId  Int
  promotionId Int
  merchantId  Int // denormalized for query performance

  /// Current stamps or points. Decremented by Promotion.threshold on each grant.
  stampCount   Int @default(0)
  pointBalance Int @default(0)

  /// Milestones available to redeem now. Tracked explicitly (not computed) for
  /// efficient notification queries (WHERE milestonesAvailable > 0).
  /// Increments when balance crosses a new threshold multiple; decrements on grant.
  milestonesAvailable Int @default(0)

  /// Lifetime total earned (stamps or points). Never decrements — for reporting only.
  lifetimeEarned Int @default(0)

  /// Timestamp of the most recent earn event. Used to enforce Promotion.timeframeDays.
  /// null = no earn event yet.
  lastEarnedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  consumer    Consumer          @relation(fields: [consumerId], references: [id])
  promotion   Promotion         @relation(fields: [promotionId], references: [id])
  merchant    Merchant          @relation(fields: [merchantId], references: [id])
  redemptions PromoRedemption[]

  /// Tiered promotions: current tier level reached (permanent, never resets)
  currentTierLevel     Int       @default(0) // 0 = no tier yet, 1 = Bronze, etc.

  /// Precedence engine: why this promo was selected last time
  lastPrecedenceReason String?   // closest_to_expiry, closest_to_milestone, highest_value, only_one_promo
  lastPrecedenceAt     DateTime?

  @@unique([consumerId, promotionId])
  @@index([merchantId])
  @@index([promotionId])
  @@index([consumerId, milestonesAvailable])
}

/// Audit log for precedence engine decisions.
/// One row per transaction where multiple promos were evaluated.
model PromotionPrecedenceLog {
  id                Int      @id @default(autoincrement())
  consumerId        Int
  merchantId        Int
  visitId           Int?
  winnerPromotionId Int?
  reason            String   // bundle_governs, reward_ready, closest_to_expiry,
                             // closest_to_milestone, highest_value, only_one_promo
  multiplierApplied Boolean  @default(false)
  multiplier        Float    @default(1.0)
  stampsAwarded     Int      @default(0)
  candidateCount    Int      @default(1)
  createdAt         DateTime @default(now())

  @@index([consumerId, merchantId])
  @@index([merchantId, createdAt])
  @@index([reason, createdAt])
}

// ── Redemption ──────────────────────────────────────────────────

/// One reward grant event — created when consumer confirms intent to redeem.
model PromoRedemption {
  id          Int @id @default(autoincrement())
  progressId  Int?  // null for referral rewards (no stamp progress)
  promotionId Int
  consumerId  Int
  merchantId  Int // denormalized

  /// Stamps or points consumed (= Promotion.threshold at time of redemption).
  pointsDecremented Int
  balanceBefore     Int
  balanceAfter      Int

  status RedemptionStatus @default(pending)

  /// Short-lived token for consumer's redemption QR shown to POS.
  /// null when grant is POS-initiated without prior consumer request.
  redemptionToken          String?   @unique @db.VarChar(64)
  redemptionTokenExpiresAt DateTime?

  /// Populated when status → granted.
  grantedAt        DateTime?
  grantedByUserId  Int?    // User.id of the POS employee who granted (null if programmatic)
  grantedByStoreId Int?    // Store.id where the grant happened
  grantNote        String? @db.VarChar(500)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  progress   ConsumerPromoProgress? @relation(fields: [progressId], references: [id])
  promotion  Promotion             @relation(fields: [promotionId], references: [id])
  consumer   Consumer              @relation(fields: [consumerId], references: [id])
  grantedBy  User?                 @relation("GrantedByUser", fields: [grantedByUserId], references: [id])
  grantStore Store?                @relation("RedemptionGrantStore", fields: [grantedByStoreId], references: [id])

  @@index([consumerId, status])
  @@index([merchantId, status])
  @@index([progressId])
  @@index([redemptionToken])
}

/**
 * ===============================
 * Bundles (Prepaid Credits) v2
 * ===============================
 * Rule-tree based prepaid credits. The ruleTreeJson defines what products
 * and combinations a bundle covers (PRODUCT / AND / OR nodes, max 2 levels).
 * PV does not process payments. Sale recorded by staff; backend creates BundleInstance.
 * Phase B/C (consumer identity + POS redemption) deferred until Scan & Visit is ready.
 */

model Bundle {
  id           Int          @id @default(autoincrement())
  merchantId   Int
  name         String       @db.VarChar(200)
  /// Rule tree defining what this bundle covers.
  /// Root: PRODUCT | AND | OR. Max 3 levels deep.
  /// Example: { type:"AND", children:[{type:"PRODUCT",productId:1,productName:"Coffee",quantity:10},...] }
  ruleTreeJson Json
  /// Sale price in dollars (e.g. 45.00)
  price        Decimal      @db.Decimal(10, 2)
  /// Date the bundle goes / went live. Required before staging.
  startAt      DateTime?
  /// Optional end date. null = runs until manually suspended or archived.
  endAt        DateTime?
  status       BundleStatus @default(wip)
  /// How redemptions are applied: "simple" = one tap consumes one set of all products.
  redemptionMode String @default("simple")
  /// AI-generated (and merchant-editable) terms & conditions shown to consumers at point of sale.
  legalText    String?      @db.Text
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  merchant        Merchant         @relation(fields: [merchantId], references: [id])
  bundleInstances BundleInstance[]
  auditLogs       BundleAuditLog[]

  @@index([merchantId, status])
}

/// One consumer's purchased bundle. Created by staff "Sell Bundle" action.
/// consumerId is nullable until Phase B (consumer identity) is live.
model BundleInstance {
  id                    Int                  @id @default(autoincrement())
  bundleId              Int
  /// Consumer who owns this bundle. Nullable until Phase B (consumer identity) is live.
  consumerId            Int?
  /// Store where this bundle was sold. Set on POS sell.
  storeId               Int?
  /// POS associate who sold this bundle.
  soldByUserId          Int?
  /// Snapshot of the rule tree at purchase time — immutable audit record.
  originalRuleTreeJson  Json
  /// Live state of the rule tree — mutated on each redemption tap.
  remainingRuleTreeJson Json
  status                BundleInstanceStatus @default(active)
  expiresAt             DateTime?
  /// Timestamp when instance was fully redeemed (status → redeemed).
  redeemedAt            DateTime?
  createdAt             DateTime             @default(now())

  bundle       Bundle                     @relation(fields: [bundleId], references: [id])
  eventMarkers BundleInstanceEventMarker[]

  @@index([bundleId])
  @@index([consumerId])
}

/// Dedup table — prevents double-firing events from POS retries or network replays.
model BundleInstanceEventMarker {
  id               Int      @id @default(autoincrement())
  bundleInstanceId Int
  eventType        String   @db.VarChar(100)
  /// Unique key per event occurrence (e.g. transactionRef + eventType)
  eventKey         String   @db.VarChar(255)
  emittedAt        DateTime @default(now())

  bundleInstance BundleInstance @relation(fields: [bundleInstanceId], references: [id])

  @@unique([bundleInstanceId, eventType, eventKey])
  @@index([bundleInstanceId])
}

/// Immutable audit trail for every bundle change.
/// Never deleted. Records actor, action type, and JSON diff of changed fields.
model BundleAuditLog {
  id          Int      @id @default(autoincrement())
  bundleId    Int
  /// null = system-initiated (e.g. auto-activate on startAt)
  actorUserId Int?
  /// e.g. "created", "updated", "status_changed"
  action      String   @db.VarChar(100)
  /// JSON diff of changed fields
  changes     Json?
  createdAt   DateTime @default(now())

  bundle Bundle @relation(fields: [bundleId], references: [id])

  @@index([bundleId, createdAt])
  @@index([actorUserId])
}

model PromoAuditLog {
  id          Int      @id @default(autoincrement())
  promotionId Int
  actorUserId Int?
  action      String   @db.VarChar(100)
  changes     Json?
  createdAt   DateTime @default(now())

  promotion Promotion @relation(fields: [promotionId], references: [id])

  @@index([promotionId, createdAt])
  @@index([actorUserId])
}

/// Bundle lifecycle status.
/// wip → staged → live → suspended → archived
enum BundleStatus {
  wip        // Being built; not visible or sellable
  staged     // Scheduled; startAt set; not yet live
  live       // Active and sellable
  suspended  // Halted; existing credits still redeemable; no new sales
  archived   // Ended; never deleted; can be duplicated as new wip
}

/// BundleInstance lifecycle status.
enum BundleInstanceStatus {
  active    // Credits remaining
  redeemed  // Fully used
  expired   // Past expiresAt before fully used
}

/// Visit lifecycle states (Thread 1)
enum VisitStatus {
  pending_identity  // Visit created, no consumer attached yet
  identified        // Consumer resolved — full actions allowed
  anonymous         // Consumer declined identity — preview/eval only
  evaluated         // Engines have run — terminal state
  abandoned         // Visit never completed — terminal state
}

/// Entitlement types (Thread 1)
enum EntitlementType {
  reward
  bundle
  registration
}

/// Entitlement lifecycle status (Thread 1)
enum EntitlementStatus {
  active
  redeemed
  expired
  revoked
}

/// Platform-level configuration — editable by pv_admin via admin panel.
/// One row per setting key; value is always stored as a string.
model PlatformConfig {
  key       String   @id @db.VarChar(100)
  value     String   @db.VarChar(500)
  updatedAt DateTime @updatedAt
  updatedBy Int?     // userId of the pv_admin who last changed it
}

// ============================================================================
// POS ADAPTER LAYER — Square (Phase 1)
// ============================================================================

/// OAuth credentials + connection state for a POS integration.
/// One row per merchant per posType.
model PosConnection {
  id                 Int      @id @default(autoincrement())
  merchantId         Int
  merchant           Merchant @relation(fields: [merchantId], references: [id])
  posType            String   @db.VarChar(32)   // "square" | "clover" | "lightspeed" | "toast"
  externalMerchantId String   @db.VarChar(128)  // Square merchant_id
  accessTokenEnc     String                     // AES-256-GCM encrypted access token
  refreshTokenEnc    String?                    // AES-256-GCM encrypted refresh token (if applicable)
  tokenExpiresAt     DateTime?
  status             String   @default("active") @db.VarChar(20) // "active" | "revoked" | "expired"
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Catalog sync tracking
  lastCatalogSyncAt      DateTime?
  lastCatalogSyncSummary Json?     // { categoriesCreated, categoriesUpdated, productsCreated, productsUpdated }

  locationMaps   PosLocationMap[]
  products       Product[]
  catalogSyncLog CatalogSyncLog[]
  giftCards               ConsumerGiftCard[]
  duplicateCustomerAlerts DuplicateCustomerAlert[]
  rewardDiscounts         PosRewardDiscount[]

  @@unique([merchantId, posType])
  @@index([merchantId])
  @@index([posType, externalMerchantId])
}

/// Gift card reference — links a PV consumer to their Square gift card.
/// One card per consumer per PosConnection. Reused across multiple rewards.
model ConsumerGiftCard {
  id                Int           @id @default(autoincrement())
  consumerId        Int
  consumer          Consumer      @relation(fields: [consumerId], references: [id])
  posConnectionId   Int
  posConnection     PosConnection @relation(fields: [posConnectionId], references: [id])
  squareGiftCardId  String        @db.VarChar(128)
  squareGan         String?       @db.VarChar(32)
  active            Boolean       @default(true)
  expiresAt         DateTime?
  createdAt         DateTime      @default(now())

  events    GiftCardEvent[]

  @@unique([consumerId, posConnectionId])
  @@index([consumerId])
}

/// Audit/analytics log for gift card lifecycle events.
/// Square is source of truth for balance; this tracks PV-side actions.
model GiftCardEvent {
  id              Int              @id @default(autoincrement())
  giftCardId      Int
  giftCard        ConsumerGiftCard @relation(fields: [giftCardId], references: [id])
  consumerId      Int
  merchantId      Int
  promotionId     Int?
  eventType       String           @db.VarChar(32) // LOAD, PRESENTED, REDEEMED, ADJUST, RECONCILED
  amountCents     Int?
  ganLast4        String?          @db.VarChar(4)
  payloadJson     Json?
  createdAt       DateTime         @default(now())

  @@index([giftCardId])
  @@index([consumerId])
  @@index([merchantId])
  @@index([eventType])
  @@index([createdAt])
}

/// Alert when duplicate Square customers share the same phone number.
/// Created on customer.created webhook or payment processing.
/// Merchant associate resolves via merchant portal / mobile app.
model DuplicateCustomerAlert {
  id                  Int      @id @default(autoincrement())
  merchantId          Int
  posConnectionId     Int
  phoneE164           String   @db.VarChar(20)
  squareCustomerIds   Json     // JSON array of Square customer IDs with same phone
  status              String   @default("pending") @db.VarChar(20) // pending, resolved, dismissed
  resolvedAt          DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  merchant      Merchant      @relation(fields: [merchantId], references: [id])
  posConnection PosConnection @relation(fields: [posConnectionId], references: [id])

  @@unique([posConnectionId, phoneE164, status])
  @@index([merchantId, status])
  @@index([posConnectionId])
}

/// Tracks Clover discount rewards applied (or pending) on orders.
/// When a consumer earns a milestone, the reward is either applied instantly
/// to the current order or stored as pending for the next visit.
model PosRewardDiscount {
  id                Int           @id @default(autoincrement())
  consumerId        Int
  merchantId        Int
  posConnectionId   Int
  entitlementId     Int?
  promotionId       Int?
  cloverOrderId     String?       @db.VarChar(64)
  cloverDiscountId  String?       @db.VarChar(64)
  discountName      String        @db.VarChar(255)
  amountCents       Int?
  percentage        Int?
  rewardType        String        @db.VarChar(32) // discount_fixed, discount_pct, free_item
  status            String        @default("earned") @db.VarChar(20) // earned, activated, redeemed, expired, skipped
  skippedReason     String?       @db.VarChar(255)
  appliedAt         DateTime?
  expiresAt         DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  consumer      Consumer      @relation(fields: [consumerId], references: [id])
  merchant      Merchant      @relation(fields: [merchantId], references: [id])
  posConnection PosConnection @relation(fields: [posConnectionId], references: [id])

  @@index([consumerId, merchantId, status])
  @@index([posConnectionId])
  @@index([entitlementId])
}

/// Consumer check-in at a store — presence detection for geofencing and analytics.
/// Does NOT create a visit or stamp. Purely notification + analytics.
model ConsumerCheckin {
  id               Int       @id @default(autoincrement())
  consumerId       Int
  storeId          Int
  merchantId       Int
  triggeredBy      String    @db.VarChar(20) // "geofence" | "manual" | "qr"
  hadPendingReward Boolean   @default(false)
  createdAt        DateTime  @default(now())

  consumer  Consumer @relation(fields: [consumerId], references: [id])
  store     Store    @relation(fields: [storeId], references: [id])
  merchant  Merchant @relation(fields: [merchantId], references: [id])

  @@index([consumerId, storeId, createdAt])
  @@index([storeId, createdAt])
  @@index([merchantId, createdAt])
}

/// Tracks reward expiry notifications sent to consumers — dedup table.
model RewardNotification {
  id                Int       @id @default(autoincrement())
  consumerId        Int
  rewardId          Int
  rewardType        String    @db.VarChar(20) // "discount" | "giftcard"
  notificationType  String    @db.VarChar(20) // "14_day" | "7_day" | "48_hour"
  channel           String    @db.VarChar(10) // "email" | "sms"
  sentAt            DateTime  @default(now())

  @@unique([rewardId, rewardType, notificationType, channel])
  @@index([consumerId])
}

/// Pre-aggregated daily merchant metrics. Written nightly by reporting cron.
/// Dashboard queries hit this table, never raw transaction tables.
model MerchantDailySummary {
  id                       Int       @id @default(autoincrement())
  merchantId               Int
  storeId                  Int?      // null = merchant-wide aggregate
  date                     DateTime  @db.Date

  totalTransactions        Int       @default(0)
  attributedTransactions   Int       @default(0)
  unattributedTransactions Int       @default(0)
  attributionRate          Float     @default(0)

  newEnrollments           Int       @default(0)
  stampsIssued             Int       @default(0)
  milestonesReached        Int       @default(0)
  rewardsRedeemed          Int       @default(0)
  redemptionValueCents     Int       @default(0)
  rewardsExpired           Int       @default(0)
  expiredValueCents        Int       @default(0)
  budgetConsumedCents      Int       @default(0)

  discoverImpressions      Int       @default(0)
  discoverEnrollments      Int       @default(0)
  checkins                 Int       @default(0)
  geofenceCheckins         Int       @default(0)
  manualCheckins           Int       @default(0)

  activeConsumers          Int       @default(0)
  newConsumers             Int       @default(0)
  returningConsumers       Int       @default(0)

  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  merchant  Merchant @relation(fields: [merchantId], references: [id])
  store     Store?   @relation(fields: [storeId], references: [id])

  @@unique([merchantId, storeId, date])
  @@index([merchantId, date])
  @@index([storeId, date])
}

/// Pre-aggregated daily promotion metrics.
model PromotionDailySummary {
  id                    Int       @id @default(autoincrement())
  promotionId           Int
  merchantId            Int
  date                  DateTime  @db.Date

  newEnrollments        Int       @default(0)
  stampsIssued          Int       @default(0)
  milestonesReached     Int       @default(0)
  rewardsRedeemed       Int       @default(0)
  redemptionValueCents  Int       @default(0)
  rewardsExpired        Int       @default(0)
  expiredValueCents     Int       @default(0)
  activeParticipants    Int       @default(0)
  totalEnrolled         Int       @default(0)

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  promotion Promotion @relation(fields: [promotionId], references: [id])
  merchant  Merchant  @relation(fields: [merchantId], references: [id])

  @@unique([promotionId, date])
  @@index([merchantId, date])
  @@index([promotionId, date])
}

/// Pre-aggregated consumer engagement distribution snapshot.
model ConsumerEngagementSummary {
  id               Int       @id @default(autoincrement())
  merchantId       Int
  storeId          Int?
  date             DateTime  @db.Date

  visitedOnce      Int       @default(0)
  visited2to3      Int       @default(0)
  visited4to7      Int       @default(0)
  visited8plus     Int       @default(0)

  progress0to25    Int       @default(0)
  progress25to50   Int       @default(0)
  progress50to75   Int       @default(0)
  progress75to100  Int       @default(0)
  rewardReady      Int       @default(0)

  inactiveDays30   Int       @default(0)
  inactiveDays60   Int       @default(0)
  inactiveDays90   Int       @default(0)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id])
  store    Store?   @relation(fields: [storeId], references: [id])

  @@unique([merchantId, storeId, date])
  @@index([merchantId, date])
}

/// Cron job execution log — visible in admin System panel.
model CronJobLog {
  id           Int       @id @default(autoincrement())
  jobName      String    @db.VarChar(64)
  status       String    @db.VarChar(20) // ok, failed
  startedAt    DateTime
  completedAt  DateTime?
  durationMs   Int?
  summary      Json?
  error        String?   @db.Text
  createdAt    DateTime  @default(now())

  @@index([jobName, startedAt])
  @@index([startedAt])
}

/// Merchant onboarding session — tracks progress through the guided setup flow.
/// Resume-able, branching, stores every answer for context-aware help.
model OnboardingSession {
  id                 Int       @id @default(autoincrement())
  merchantId         Int       @unique
  merchantUserId     Int

  // Progress
  currentStage       String    @default("pos-access") @db.VarChar(32)
  currentStep        String    @default("2.1") @db.VarChar(10)
  completedSteps     Json      @default("[]")

  // Answers
  posType            String?   @db.VarChar(20) // clover, square, toast, manual
  setupPersona       String?   @db.VarChar(20) // self, someone-else, unsure
  credentialStatus   String?   @db.VarChar(20) // ready, recovering, unknown

  // Connection
  posConnectionId    Int?
  externalMerchantId String?   @db.VarChar(20) // Clover 13-char ID — validate format
  posEnvironment     String?   @db.VarChar(20) // production, sandbox
  storesFound        Int?
  storesMapped       Int?

  // OAuth error tracking (internal)
  lastOAuthError     String?   @db.VarChar(255)
  oauthAttempts      Int       @default(0)

  // First promo
  firstPromoId       Int?
  firstPromoStatus   String?   @db.VarChar(20) // active, draft

  // Stuck/help
  stuckAtStep        String?   @db.VarChar(10)
  stuckReason        String?   @db.Text
  stuckAt            DateTime?
  helpMessages       Json      @default("[]")

  // Timestamps
  startedAt          DateTime  @default(now())
  completedAt        DateTime?
  lastActivityAt     DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id])

  @@index([merchantId])
}

/// Log of catalog sync events — tracks what changed and when.
model CatalogSyncLog {
  id              Int           @id @default(autoincrement())
  posConnectionId Int
  posConnection   PosConnection @relation(fields: [posConnectionId], references: [id])
  merchantId      Int
  trigger         String        @db.VarChar(32) // webhook | manual | onboard
  summary         Json?         // { categoriesCreated, categoriesUpdated, productsCreated, productsUpdated }
  changes         Json?         // [{ action: "created"|"updated", type: "product"|"category", name, field? }]
  createdAt       DateTime      @default(now())

  @@index([posConnectionId])
  @@index([merchantId, createdAt])
}

/// Maps a POS location (e.g. Square location_id) to a PerkValet Store.
/// A merchant may have multiple Square locations mapped to multiple PV stores.
model PosLocationMap {
  id                   Int           @id @default(autoincrement())
  posConnectionId      Int
  posConnection        PosConnection @relation(fields: [posConnectionId], references: [id])
  externalLocationId   String        @db.VarChar(128) // Square location_id
  externalLocationName String?       @db.VarChar(255)
  pvStoreId            Int
  pvStoreName          String?       @db.VarChar(255) // denormalized for quick display
  active               Boolean       @default(true)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@unique([posConnectionId, externalLocationId])
  @@index([pvStoreId])
  @@index([externalLocationId])
}

model PosOrder {
  id              Int      @id @default(autoincrement())
  visitId         Int      @unique
  visit           Visit    @relation(fields: [visitId], references: [id])
  merchantId      Int
  merchant        Merchant @relation(fields: [merchantId], references: [id])
  storeId         Int
  store           Store    @relation(fields: [storeId], references: [id])
  consumerId      Int?
  consumer        Consumer? @relation(fields: [consumerId], references: [id])
  externalOrderId String   @db.VarChar(128)
  posType         String   @default("square") @db.VarChar(32)
  orderState      String?  @db.VarChar(32)   // COMPLETED, CANCELED, etc.
  totalAmount     Int?                        // cents
  totalTax        Int?                        // cents
  totalDiscount   Int?                        // cents
  totalTip        Int?                        // cents
  currency        String   @default("USD") @db.VarChar(3)
  rawJson         Json?                       // full Square order response
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  items           PosOrderItem[]

  @@index([merchantId, createdAt])
  @@index([storeId, createdAt])
  @@index([consumerId])
  @@index([externalOrderId])
}

model PosOrderItem {
  id              Int      @id @default(autoincrement())
  posOrderId      Int
  posOrder        PosOrder @relation(fields: [posOrderId], references: [id], onDelete: Cascade)
  itemName        String?  @db.VarChar(255)
  itemSku         String?  @db.VarChar(128)   // catalog_object_id from Square
  upc             String?  @db.VarChar(14)    // UPC-A, UPC-E, EAN-13, GTIN-14
  variationName   String?  @db.VarChar(255)   // e.g. "Large"
  variationId     String?  @db.VarChar(128)   // catalog variation ID
  categoryName    String?  @db.VarChar(255)
  quantity        Int      @default(1)
  unitPrice       Int?                         // cents
  totalPrice      Int?                         // cents
  totalTax        Int?                         // cents
  totalDiscount   Int?                         // cents
  itemType        String?  @db.VarChar(64)     // ITEM, CUSTOM_AMOUNT, etc.
  rawJson         Json?                        // raw line_item from Square
  createdAt       DateTime @default(now())

  @@index([posOrderId])
  @@index([itemSku])
  @@index([upc])
}

// ============================================================================
// GROWTH ADVISOR — Promotion Outcomes (analytical layer)
// ============================================================================

/// Event-level activity feeding aggregate calculations.
/// Fire-and-forget from transactional flows — never blocks POS.
model PromotionEvent {
  id            Int      @id @default(autoincrement())
  promotionId   Int
  promotion     Promotion @relation(fields: [promotionId], references: [id])
  merchantId    Int
  merchant      Merchant  @relation(fields: [merchantId], references: [id])
  storeId       Int?
  consumerId    Int?
  eventType     String   @db.VarChar(32) // clip | qualify | grant | redeem
  posOrderId    Int?
  visitId       Int?
  valueCents    Int?
  payloadJson   Json?
  createdAt     DateTime @default(now())

  @@index([promotionId])
  @@index([merchantId])
  @@index([consumerId])
  @@index([eventType])
  @@index([createdAt])
}

/// Baseline snapshot captured when a promotion activates.
/// Used for lift calculations in PromotionOutcome.
model PromotionBaselineSnapshot {
  id                 Int      @id @default(autoincrement())
  promotionId        Int
  promotion          Promotion @relation(fields: [promotionId], references: [id])
  merchantId         Int
  merchant           Merchant  @relation(fields: [merchantId], references: [id])
  storeId            Int?
  capturedAt         DateTime @default(now())
  avgOrderValueCents Int?
  dailyRevenueCents  Int?
  visitFrequencyDays Float?
  repeatRate         Float?

  @@index([promotionId])
  @@index([merchantId])
}

/// Aggregated promotion effectiveness metrics.
/// Computed async from PromotionEvent + PromotionBaselineSnapshot.
/// Extended with simulator learning-loop fields for objective-driven projections.
model PromotionOutcome {
  id                 Int       @id @default(autoincrement())
  promotionId        Int
  promotion          Promotion @relation(fields: [promotionId], references: [id])
  merchantId         Int
  merchant           Merchant  @relation(fields: [merchantId], references: [id])
  storeId            Int?
  startDate          DateTime
  endDate            DateTime?

  // Activity counts
  clips              Int       @default(0)
  qualifiedPurchases Int       @default(0)
  rewardsGranted     Int       @default(0)
  rewardsRedeemed    Int       @default(0)

  // Lift metrics (decimal fractions, e.g. 0.14 = +14%)
  redemptionRate     Float?
  repeatVisitLift    Float?
  aovLift            Float?
  revenueLift        Float?
  timeSlotLift       Float?

  // Baseline reference values
  baselineAovCents     Int?
  baselineVisits       Float?
  baselineRevenueCents Int?

  // Simulator learning loop — projected vs actual comparison
  objective                String?   // bring-back | grow-base | drive-revenue | fill-slow | reward-best
  primaryMetricProjected   Float?    // what simulator predicted
  primaryMetricActual      Float?    // what actually happened
  revenueProjectedCents    Int?
  revenueActualCents       Int?
  costProjectedCents       Int?
  costActualCents          Int?
  enrollmentProjected      Int?
  enrollmentActual         Int?
  attributionRateAvg       Float?    // avg attribution rate during promotion
  durationDays             Int?

  computedAt         DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([promotionId])
  @@index([merchantId])
  @@index([storeId])
}

// ═══════════════════════════════════════════════════════════════
// Payment Event Ledger — immutable, append-only audit trail
// Used by: Square, Stripe, Grocery subsidy, future payment sources
// ═══════════════════════════════════════════════════════════════

enum PaymentEventSource {
  square
  stripe
  clover
  toast
  grocery
  manual
}

enum PaymentEventType {
  payment_created
  payment_completed
  payment_failed
  payment_refunded
  subsidy_applied
  subsidy_reversed
  settlement_generated
}

model PaymentEvent {
  id                Int                @id @default(autoincrement())

  /// Event classification
  eventType         PaymentEventType
  source            PaymentEventSource

  /// Business context
  merchantId        Int
  merchant          Merchant           @relation(fields: [merchantId], references: [id])
  storeId           Int?
  store             Store?             @relation("PaymentEventStore", fields: [storeId], references: [id])

  /// Consumer identity (phone for grocery, consumerId for loyalty)
  consumerId        Int?
  phone             String?            @db.VarChar(20)

  /// Financial
  amountCents       Int                @default(0)
  currency          String             @default("usd") @db.VarChar(3)

  /// Provider references (immutable once written)
  providerEventId   String?            @db.VarChar(255)  // Square payment ID, Stripe PI ID, transaction ID
  providerOrderId   String?            @db.VarChar(255)  // Square order ID, invoice ID
  promotionId       Int?                                 // Linked promotion (for subsidy/loyalty)
  transactionId     String?            @db.VarChar(100)  // Logical transaction grouping (e.g. grocery basket)

  /// Product reference (for grocery UPC events)
  upc               String?            @db.VarChar(50)
  productName       String?

  /// Unstructured details (provider-specific payload)
  metadataJson      Json?

  /// Immutable timestamp — no updatedAt by design
  createdAt         DateTime           @default(now())

  @@index([source, merchantId])
  @@index([merchantId, createdAt])
  @@index([source, eventType])
  @@index([transactionId])
  @@index([providerEventId])
  @@index([phone])
  @@index([storeId])
}

// ═══════════════════════════════════════════════════════════════
// Event Outbox — transactional event staging for durable delivery
// Written in the same DB transaction as business truth.
// Publisher reads pending rows and dispatches to consumers.
// ═══════════════════════════════════════════════════════════════

enum EventOutboxStatus {
  pending
  published
  failed
  dead_lettered
}

model EventOutbox {
  id               Int                @id @default(autoincrement())

  /// Event identity (UUID, generated at write time)
  eventId          String             @unique @db.VarChar(36)

  /// Event classification
  eventType        String             @db.VarChar(100)
  aggregateType    String             @db.VarChar(50)    // e.g. "reward", "visit", "promotion", "subsidy"
  aggregateId      String             @db.VarChar(100)   // e.g. reward ID, visit ID

  /// Lineage — trace cause-and-effect chains
  correlationId    String?            @db.VarChar(36)    // groups related events (e.g. one scan → visit + reward + notification)
  causationId      String?            @db.VarChar(36)    // the eventId that caused this event

  /// Idempotency — prevents duplicate event creation
  idempotencyKey   String             @unique @db.VarChar(200)

  /// Business context
  merchantId       Int?
  storeId          Int?
  consumerId       Int?

  /// Event data
  payloadJson      Json

  /// Publish state
  status           EventOutboxStatus  @default(pending)
  publishAttempts  Int                @default(0)
  maxAttempts      Int                @default(5)
  nextAttemptAt    DateTime           @default(now())
  publishedAt      DateTime?
  lastError        String?

  /// Deliveries
  deliveries       EventDelivery[]

  /// Timestamps
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([status, nextAttemptAt])
  @@index([eventType])
  @@index([aggregateType, aggregateId])
  @@index([correlationId])
  @@index([merchantId])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════
// Event Delivery — per-consumer processing accounting
// Tracks which consumers received, processed, or failed each event.
// Enables: posted vs processed auditing, retry visibility, dead-letter recovery.
// ═══════════════════════════════════════════════════════════════

enum EventDeliveryStatus {
  pending
  processing
  processed
  failed
  dead_lettered
}

model EventDelivery {
  id               Int                   @id @default(autoincrement())

  /// Link to the outbox event
  outboxEventId    Int
  outbox           EventOutbox           @relation(fields: [outboxEventId], references: [id])
  eventId          String                @db.VarChar(36)   // denormalized from outbox for query convenience

  /// Consumer identity
  consumerName     String                @db.VarChar(100)  // e.g. "notification", "walletRefresh", "settlementAccrual"

  /// Processing state
  status           EventDeliveryStatus   @default(pending)
  attempts         Int                   @default(0)
  maxAttempts      Int                   @default(3)

  /// Timing
  startedAt        DateTime?
  completedAt      DateTime?
  nextRetryAt      DateTime?
  lastError        String?

  /// Result metadata (optional — consumer can store output)
  resultJson       Json?

  /// Timestamps
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@unique([outboxEventId, consumerName])
  @@index([status])
  @@index([consumerName, status])
  @@index([eventId])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════
// CPG Entity — Consumer Packaged Goods company (General Mills, P&G, etc.)
// Sets settlement rules that all their promotions inherit.
// ═══════════════════════════════════════════════════════════════

enum CpgStatus {
  active
  inactive
}

enum FeeHandling {
  cpg_pays
  shared
  merchant_pays
}

model CpgEntity {
  id                    Int          @id @default(autoincrement())
  name                  String       @unique
  status                CpgStatus    @default(active)

  /// Settlement policy
  settlementCadence     String       @default("weekly") @db.VarChar(30)  // weekly, net_15, net_30, monthly
  payoutDelayDays       Int          @default(7)
  disputeWindowDays     Int          @default(14)
  minimumPayoutCents    Int          @default(5000)    // $50.00 default
  feeHandling           FeeHandling  @default(cpg_pays)
  platformFeeCents      Int          @default(0)       // per-transaction fee PV charges

  /// Future: brand-level overrides
  brandOverridesJson    Json?

  /// Opt-in policy
  merchantOptInRequired Boolean      @default(true)

  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  participations        CpgParticipation[]
  accruals              SettlementAccrual[]
  batches               SettlementBatch[]

  @@index([status])
}

// ═══════════════════════════════════════════════════════════════
// CPG Participation — merchant opt-in/decline/pause per CPG
// ═══════════════════════════════════════════════════════════════

enum CpgParticipationStatus {
  active
  declined
  paused
}

model CpgParticipation {
  id            Int                      @id @default(autoincrement())
  cpgId         Int
  cpg           CpgEntity                @relation(fields: [cpgId], references: [id])
  merchantId    Int
  merchant      Merchant                 @relation(fields: [merchantId], references: [id])
  status        CpgParticipationStatus   @default(active)
  agreedAt      DateTime?
  declinedAt    DateTime?
  pausedAt      DateTime?
  reason        String?

  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  @@unique([cpgId, merchantId])
  @@index([merchantId])
  @@index([cpgId, status])
}

// ═══════════════════════════════════════════════════════════════
// Settlement Accrual — durable financial obligation entries
// CPG owes merchant for subsidies applied. Linked to source events.
// ═══════════════════════════════════════════════════════════════

enum AccrualStatus {
  open          // accrued, not yet batched
  batched       // included in a settlement batch
  paid          // settlement paid out
  disputed      // merchant or CPG raised a dispute
  reversed      // accrual reversed (e.g. fraud)
}

model SettlementAccrual {
  id                Int            @id @default(autoincrement())

  /// Source event linkage (idempotency)
  sourceEventId     String         @unique @db.VarChar(36)  // eventId from outbox
  correlationId     String?        @db.VarChar(36)

  /// Parties
  cpgId             Int
  cpg               CpgEntity      @relation(fields: [cpgId], references: [id])
  merchantId        Int
  merchant          Merchant       @relation(fields: [merchantId], references: [id])
  storeId           Int?
  consumerId        Int?
  promotionId       Int?

  /// Financial
  grossAmountCents  Int            @default(0)   // subsidy amount
  feeAmountCents    Int            @default(0)   // PV platform fee
  netAmountCents    Int            @default(0)   // gross - fee = what merchant gets
  currency          String         @default("usd") @db.VarChar(3)

  /// State
  status            AccrualStatus  @default(open)
  effectiveAt       DateTime       @default(now())  // when the subsidy was applied

  /// Batch linkage (filled when batched)
  batchId           Int?

  /// Product reference (for grocery)
  upc               String?        @db.VarChar(50)
  transactionId     String?        @db.VarChar(100)

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([cpgId, status])
  @@index([merchantId, status])
  @@index([status])
  @@index([batchId])
  @@index([transactionId])
  @@index([effectiveAt])
}

// ═══════════════════════════════════════════════════════════════
// Settlement Batch — groups open accruals into payable batches
// One batch per CPG per settlement window.
// ═══════════════════════════════════════════════════════════════

enum SettlementBatchStatus {
  open        // accumulating accruals
  finalized   // locked, ready for payout
  paid        // funds disbursed
  failed      // payout failed
}

model SettlementBatch {
  id                  Int                    @id @default(autoincrement())
  cpgId               Int
  cpg                 CpgEntity              @relation(fields: [cpgId], references: [id])

  /// Window
  periodStart         DateTime
  periodEnd           DateTime
  cadence             String                 @db.VarChar(30)  // weekly, net_15, etc.

  /// Totals (computed from items)
  totalGrossCents     Int                    @default(0)
  totalFeeCents       Int                    @default(0)
  totalNetCents       Int                    @default(0)
  itemCount           Int                    @default(0)

  /// State
  status              SettlementBatchStatus  @default(open)
  finalizedAt         DateTime?
  paidAt              DateTime?
  paymentReference    String?                @db.VarChar(255)  // external payment ref
  lastError           String?

  /// Audit
  createdBy           Int?                   // pv_admin userId who triggered
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  items               SettlementBatchItem[]

  @@index([cpgId, status])
  @@index([status])
  @@index([periodStart, periodEnd])
}

model SettlementBatchItem {
  id              Int               @id @default(autoincrement())
  batchId         Int
  batch           SettlementBatch   @relation(fields: [batchId], references: [id])
  accrualId       Int
  merchantId      Int
  grossAmountCents Int
  feeAmountCents  Int
  netAmountCents  Int

  createdAt       DateTime          @default(now())

  @@index([batchId])
  @@index([merchantId])
  @@index([accrualId])
}

// ═══════════════════════════════════════════════════════════════
// AI Support Pipeline
// ═══════════════════════════════════════════════════════════════

/// Logs every agent pipeline step — every run, every result.
model PlatformAgentLog {
  id              Int      @id @default(autoincrement())
  agentName       String   // agent.1.reader, agent.2.structurer, etc.
  triggeredBy     String   // deploy, agent1, schedule, manual
  status          String   // running, complete, failed, skipped
  inputHash       String?
  outputHash      String?
  outputChanged   Boolean  @default(false)
  durationMs      Int?
  errorMessage    String?
  buildVersion    String?
  createdAt       DateTime @default(now())

  @@index([agentName, createdAt])
  @@index([status, createdAt])
}

/// Generated help content — persists across deploys (Render filesystem is ephemeral).
model GeneratedHelpPage {
  id        Int      @id @default(autoincrement())
  pageId    String   @unique // e.g. "merchant_dashboard", "admin_system"
  content   String   @db.Text
  charCount Int      @default(0)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([pageId])
}

/// Pre-populated support ticket — zero merchant input required.
/// AI diagnosis + full platform context captured automatically.
model SupportTicket {
  id                  Int      @id @default(autoincrement())
  merchantId          Int
  merchant            Merchant @relation(fields: [merchantId], references: [id])
  page                String   // route where issue occurred
  action              String?  // what they were trying to do
  lastError           Json?    // API error details
  aiDiagnosis         String?  // AI's diagnosis text
  aiConfidence        String?  // high, medium, low
  resolutionAttempted Json?    // steps AI suggested
  platformSnapshot    Json     // full support context at time of issue
  eventLog            Json     // recent pvHook events
  posType             String?
  daysOnPlatform      Int?
  billingStage        String?
  status              String   @default("open") // open, in_progress, resolved
  priority            String   @default("normal") // critical, high, normal
  resolvedAt          DateTime?
  resolutionNote      String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([status, priority, createdAt])
  @@index([merchantId])
}
